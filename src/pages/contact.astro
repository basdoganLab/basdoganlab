---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact',
  description: 'Contact and collaboration details for Basdogan Lab.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Contact</h1>
    <p class="mt-4 text-lg text-gray-700">
      We welcome research collaborations, prospective students, and industrial partnerships.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-gray-900">PI Contact</h2>
        <p class="mt-3 text-gray-700">Yasemin Basdogan</p>
        <p class="text-gray-700">
          Email: <a class="text-sky-700 hover:underline" href="mailto:yaseminbasdogan@rochester.edu">yaseminbasdogan@rochester.edu</a>
        </p>
        <p class="text-gray-700">
          Office: 4305 Wegmans Hall<br />
          University of Rochester<br />
          P.O. 270166<br />
          Rochester, NY 14627-0166
        </p>
      </article>

      <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-gray-900">Student Applications</h2>
        <p class="mt-3 text-gray-700">Send CV, transcript, and a short research statement.</p>
        <p class="mt-2 text-gray-700">Include relevant software and modeling experience.</p>
        <p class="mt-2 text-gray-700">Subject line: "Prospective Student - Your Name"</p>
      </article>
    </div>
  </section>
</Layout>
