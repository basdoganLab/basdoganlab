---
import Layout from '~/layouts/PageLayout.astro';
import teamData from '~/data/team.json';
import { getAsset, getPermalink } from '~/utils/permalinks';

interface TeamMember {
  name: string;
  role: string;
  photo: string;
  email?: string;
  website?: string;
  researchInterests?: string[];
  bio?: string;
  previousPosition?: string;
  timeAtLab?: string;
  currentPosition?: string;
  section?: 'pi' | 'current' | 'alumni';
  order?: number;
}

const metadata = {
  title: 'Team',
  description: 'Meet the Basdogan Lab team.',
};

const resolvePhoto = (photo: string) =>
  photo.startsWith('http://') || photo.startsWith('https://') ? photo : getAsset(photo);

const getSection = (member: TeamMember) => {
  if (member.section) return member.section;
  if (member.role === 'PI') return 'pi';
  return 'current';
};

const sections = [
  { key: 'pi', title: 'PI' },
  { key: 'current', title: 'Current Member' },
  { key: 'alumni', title: 'Alumni' },
] as const;

const sectionPriority: Record<'pi' | 'current' | 'alumni', number> = {
  pi: 0,
  current: 1,
  alumni: 2,
};

const rolePriority: Record<string, number> = {
  PI: 0,
  Postdoc: 1,
  'PhD Candidate': 2,
  PhD: 2,
  Master: 3,
  Undergraduate: 4,
  Alumni: 5,
};

const team = (teamData as TeamMember[])
  .map((member, index) => ({ ...member, originalIndex: index }))
  .sort((a, b) => {
    const sectionDiff = sectionPriority[getSection(a)] - sectionPriority[getSection(b)];
    if (sectionDiff !== 0) return sectionDiff;

    const roleDiff = (rolePriority[a.role] ?? 99) - (rolePriority[b.role] ?? 99);
    if (roleDiff !== 0) return roleDiff;

    return a.originalIndex - b.originalIndex;
  });
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Team</h1>
    <p class="mt-4 max-w-3xl text-lg text-gray-700">People driving the lab's research and collaborations.</p>

    {
      sections.map((section) => {
        const members = team.filter((member) => getSection(member) === section.key);

        return (
          <section class="mt-12 first:mt-10">
            <h2 class="text-2xl font-semibold tracking-tight text-gray-900">{section.title}</h2>
            {
              members.length ? (
                <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                  {members.map((member) => (
                    <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                      <img
                        src={resolvePhoto(member.photo)}
                        alt={`${member.name} portrait`}
                        class="h-40 w-40 rounded-full object-cover"
                        loading="lazy"
                      />
                      <h3 class="mt-4 text-xl font-semibold text-gray-900">{member.name}</h3>
                      <p class="text-sky-700 font-medium">{member.role}</p>
                      {member.previousPosition || member.timeAtLab ? (
                        <p class="mt-3 text-sm text-gray-700">
                          Previous position: {[member.previousPosition, member.timeAtLab].filter(Boolean).join(' | ')}
                        </p>
                      ) : null}
                      {member.currentPosition ? <p class="mt-2 text-sm text-gray-700">Current position: {member.currentPosition}</p> : null}
                      {member.bio ? <p class="mt-3 text-sm leading-6 text-gray-700">{member.bio}</p> : null}
                      {member.researchInterests?.length ? (
                        <p class="mt-2 text-sm text-gray-700">Interests: {member.researchInterests.join(', ')}</p>
                      ) : null}
                      <div class="mt-3 flex flex-wrap gap-3 text-sm">
                        {member.email ? <a class="text-sky-700 hover:underline" href={`mailto:${member.email}`}>Email</a> : null}
                        {member.website ? <a class="text-sky-700 hover:underline" href={member.website}>Website</a> : null}
                        {member.role === 'PI' ? <a class="text-sky-700 hover:underline" href={getPermalink('/team/pi')}>View Full Profile</a> : null}
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <p class="mt-3 text-sm text-gray-500">No team members listed in this section yet.</p>
              )
            }
          </section>
        );
      })
    }
  </section>
</Layout>
